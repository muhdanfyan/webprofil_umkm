---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const blogPosts = await getCollection("blog");
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Intl.DateTimeFormat("id-ID", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(post.data.tanggal);
---

<Layout
  title={post.data.judul}
  description={post.data.judul}
  ogImage={post.data.image}
>
  <article class="py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="mb-8">
          <a
            href="/blog"
            class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium mb-6"
          >
            ← Kembali ke Blog
          </a>

          <div class="flex items-center gap-4 mb-4">
            <span
              class="inline-block bg-primary-100 text-primary-700 px-4 py-1 rounded-full text-sm font-semibold"
            >
              {post.data.kategori}
            </span>
            <span class="text-gray-600">{formattedDate}</span>
          </div>

          <h1 class="text-5xl font-bold text-gray-900 mb-6">
            {post.data.judul}
          </h1>
        </div>

        <div class="mb-12">
          <img
            src={post.data.image}
            alt={post.data.judul}
            class="w-full rounded-2xl shadow-lg"
          />
        </div>

        <div class="prose prose-lg max-w-none">
          <Content />
        </div>

        <div class="mt-12 pt-8 border-t border-gray-200">
          <div
            class="bg-gradient-to-br from-primary-50 to-success-50 rounded-2xl p-8 text-center"
          >
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              Tertarik dengan layanan kami?
            </h3>
            <p class="text-gray-600 mb-6">
              Hubungi kami untuk konsultasi dan informasi lebih lanjut
            </p>
            <a
              href="https://wa.me/6285341053011"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-success-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-success-600 transition-colors"
            >
              Konsultasi via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  :global(.prose) {
    @apply text-gray-700 leading-relaxed;
  }

  :global(.prose h2) {
    @apply text-3xl font-bold text-gray-900 mt-8 mb-4;
  }

  :global(.prose h3) {
    @apply text-2xl font-bold text-gray-900 mt-6 mb-3;
  }

  :global(.prose p) {
    @apply mb-4;
  }

  :global(.prose ul),
  :global(.prose ol) {
    @apply mb-4 pl-6;
  }

  :global(.prose li) {
    @apply mb-2;
  }

  :global(.prose strong) {
    @apply font-bold text-gray-900;
  }

  :global(.prose em) {
    @apply italic;
  }

  :global(.prose a) {
    @apply text-primary-600 hover:text-primary-700 underline;
  }
</style>
