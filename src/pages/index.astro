---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import BlogCard from "../components/BlogCard.astro";
import {
  services,
  processSteps,
  testimonials,
  faqs,
  stats,
  educationTips,
} from "../config";
import { getEntry, getCollection } from "astro:content";

const identityEntry = await getEntry('identity', 'settings');
const identity = identityEntry?.data;

const allBlogPosts = await getCollection("blog");
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.tanggal.getTime() - a.data.tanggal.getTime())
  .slice(0, 3);
---

<Layout>
  <!-- Hero Section - Clean White with Subtle Patterns -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-white via-white to-primary-50/30 pt-8 pb-16 lg:pt-12 lg:pb-24"
  >
    <!-- Decorative Background Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Large soft circles -->
      <div
        class="absolute -top-32 -right-32 w-96 h-96 bg-primary-100/40 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-primary-50/50 rounded-full blur-3xl"
      >
      </div>

      <!-- Subtle grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: radial-gradient(circle at 1px 1px, #2ECC9B 1px, transparent 0); background-size: 40px 40px;"
      >
      </div>

      <!-- Floating decorative elements -->
      <div
        class="absolute top-20 left-[10%] w-3 h-3 bg-primary-400 rounded-full animate-float opacity-60"
      >
      </div>
      <div
        class="absolute top-40 right-[15%] w-2 h-2 bg-accent-400 rounded-full animate-float animation-delay-2000 opacity-60"
      >
      </div>
      <div
        class="absolute bottom-32 left-[20%] w-4 h-4 bg-primary-300 rounded-full animate-float animation-delay-4000 opacity-40"
      >
      </div>
      <div
        class="absolute top-1/2 right-[8%] w-2 h-2 bg-accent-300 rounded-full animate-float opacity-50"
      >
      </div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left Content -->
        <div class="text-center lg:text-left animate-fadeInLeft">
          <!-- Badge -->
          <div
            class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-sm border border-primary-100 rounded-full px-4 py-2 mb-6 shadow-sm"
          >
            <span class="w-2 h-2 bg-primary-500 rounded-full animate-pulse"
            ></span>
            <span class="text-sm font-medium text-gray-700"
              >{identity?.tagline}</span
            >
          </div>

          <h1
            class="text-3xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight"
          >
            Sunat Modern,<br />
            <span class="text-primary-500">Nyaman</span> & <span
              class="text-accent-500">Aman</span
            >
          </h1>

          <!-- Mobile Hero Image -->
          <div class="lg:hidden relative my-6 px-4">
            <div
              class="relative z-10 bg-gradient-to-br from-white to-primary-50 rounded-2xl p-3 shadow-lg shadow-primary-500/10 max-w-[280px] mx-auto"
            >
              <img
                src={identity?.logo || "/logo-wiyasa.png"}
                alt={identity?.name}
                class="w-full mx-auto"
              />
              <!-- Mobile Mascot -->
              <div
                class="absolute -top-2 -right-2 bg-white rounded-lg p-1.5 shadow-md border border-gray-100"
              >
                <img
                  src={identity?.favicon || "/favicon bearboy.png"}
                  alt={identity?.name}
                  class="w-8 h-8 object-contain"
                />
              </div>
              <!-- Mobile Stats -->
              <div
                class="absolute -bottom-2 -left-2 bg-white rounded-lg px-2 py-1.5 shadow-md border border-gray-100 flex items-center gap-1.5"
              >
                <div
                  class="w-6 h-6 bg-primary-500 rounded flex items-center justify-center"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3 h-3 text-white"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-gray-900 leading-none">
                    1000+
                  </p>
                  <p class="text-[8px] text-gray-500 leading-none">
                    Pasien Puas
                  </p>
                </div>
              </div>
            </div>
          </div>

          <p
            class="text-lg md:text-xl text-gray-600 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed"
          >
            {identity?.description}
          </p>

          <!-- CTA Buttons -->
          <div
            class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
          >
            <a
              href={identity?.contact?.whatsapp || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-3 bg-primary-500 text-white px-8 py-4 rounded-2xl text-lg font-semibold hover:bg-primary-600 transition-all duration-300 shadow-lg shadow-primary-500/25 hover:shadow-xl hover:shadow-primary-500/30 hover:-translate-y-0.5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>
              Konsultasi Gratis
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/blog"
              class="inline-flex items-center justify-center gap-2 bg-white text-gray-700 px-8 py-4 rounded-2xl text-lg font-semibold hover:bg-gray-50 transition-all duration-300 border-2 border-gray-200 hover:border-primary-200"
            >
              Baca Artikel
            </a>
          </div>

          <!-- Trust Indicators -->
          <div
            class="flex flex-wrap items-center justify-center lg:justify-start gap-6 mt-10 pt-8 border-t border-gray-100"
          >
            <div class="flex items-center gap-2">
              <div
                class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-primary-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
              </div>
              <span class="text-sm font-medium text-gray-600"
                >Aman & Steril</span
              >
            </div>
            <div class="flex items-center gap-2">
              <div
                class="w-10 h-10 bg-accent-100 rounded-full flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-accent-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <span class="text-sm font-medium text-gray-600">Proses Cepat</span
              >
            </div>
            <div class="flex items-center gap-2">
              <div
                class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-primary-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                  ></path>
                </svg>
              </div>
              <span class="text-sm font-medium text-gray-600"
                >Tanpa Rasa Sakit</span
              >
            </div>
          </div>
        </div>

        <!-- Right - Hero Image (Desktop Only) -->
        <div class="relative animate-fadeInRight hidden lg:block">
          <!-- Decorative rings -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div
              class="w-72 h-72 md:w-96 md:h-96 border-2 border-primary-200/50 rounded-full animate-spin-slow"
            >
            </div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div
              class="w-64 h-64 md:w-80 md:h-80 border border-primary-100/50 rounded-full animate-spin-reverse"
            >
            </div>
          </div>

          <!-- Main Image Container -->
          <div
            class="relative z-10 bg-gradient-to-br from-white to-primary-50 rounded-3xl p-4 shadow-2xl shadow-primary-500/10"
          >
            <img
              src="/images/heroes/hero-main.png"
              alt={`Selamat Datang di ${identity?.name}`}
              class="w-full max-w-md mx-auto drop-shadow-lg animate-float"
            />
          </div>

          <!-- Floating Card - Top Right (Mascot) -->
          <div
            class="absolute -top-4 -right-4 md:top-4 md:-right-8 bg-white rounded-2xl p-3 shadow-xl border border-gray-100 animate-float z-20"
          >
            <img
              src={identity?.favicon || "/favicon bearboy.png"}
              alt={`${identity?.name} Mascot`}
              class="w-14 h-14 md:w-16 md:h-16 object-contain"
            />
          </div>

          <!-- Floating Card - Bottom Left (Stats) -->
          <div
            class="absolute -bottom-4 -left-4 md:bottom-8 md:-left-8 bg-white rounded-2xl p-4 shadow-xl border border-gray-100 animate-bounce-subtle z-20"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-12 h-12 bg-gradient-to-br from-primary-400 to-primary-600 rounded-xl flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-6 h-6 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-900">1000+</p>
                <p class="text-xs text-gray-500">Pasien Puas</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <!-- Decorative Background -->
    <div
      class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-200 to-transparent"
    >
    </div>
    <div
      class="absolute -top-32 right-0 w-64 h-64 bg-primary-50 rounded-full blur-3xl opacity-60"
    >
    </div>
    <div
      class="absolute -bottom-32 left-0 w-80 h-80 bg-primary-50 rounded-full blur-3xl opacity-40"
    >
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="text-center mb-16">
        <span
          class="inline-block px-5 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4 border border-primary-100"
        >
          Layanan Profesional
        </span>
        <h2
          class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4"
        >
          Layanan <span class="text-primary-500">Kami</span>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Berbagai pilihan layanan sunat sesuai kebutuhan Anda dengan standar
          kualitas terbaik
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {
          services.map((service, index) => (
            <div
              class="group bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border border-gray-100 hover:border-primary-200 transform hover:-translate-y-2"
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class="relative overflow-hidden">
                <img
                  src={service.image}
                  alt={service.title}
                  class="w-full h-56 object-cover group-hover:scale-110 transition-transform duration-700"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 via-gray-900/20 to-transparent" />
                <div class="absolute bottom-4 left-4 right-4">
                  <span class="inline-block px-3 py-1 bg-white/90 backdrop-blur-sm text-primary-600 text-xs font-semibold rounded-full">
                    Tersedia
                  </span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors">
                  {service.title}
                </h3>
                <p class="text-gray-600 mb-6 line-clamp-3 leading-relaxed">
                  {service.description}
                </p>
                <a
                  href={identity?.contact?.whatsapp || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-primary-500 text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-600 transition-all duration-300 hover:gap-3 shadow-md hover:shadow-lg"
                >
                  Konsultasi
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-24 bg-gradient-to-br from-gray-50 via-white to-primary-50/30 relative overflow-hidden">
    <!-- Decorative Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary-100 rounded-full opacity-40 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-100 rounded-full opacity-30 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-primary-100 rounded-full opacity-20"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <!-- Header -->
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-5 py-2 bg-white text-primary-700 rounded-full text-sm font-semibold mb-4 border border-primary-100 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          Kenapa Memilih Kami
        </span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          Keunggulan <span class="bg-gradient-to-r from-primary-500 to-primary-600 bg-clip-text text-transparent">{identity?.name}</span>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Kami berkomitmen memberikan layanan sunat terbaik dengan standar profesional tinggi
        </p>
      </div>

      <!-- Features Grid -->
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
        {identity?.advantages?.map((advantage, index) => (
          <div class={`group relative bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 overflow-hidden ${index % 2 === 0 ? 'hover:border-primary-200' : 'hover:border-accent-200'}`}>
            <!-- Decorative gradient -->
            <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl rounded-bl-full opacity-50 ${index % 2 === 0 ? 'from-primary-100' : 'from-accent-100'} to-transparent`}></div>
            
            <div class="relative z-10 flex flex-col lg:flex-row items-start gap-6">
              <div class={`w-20 h-20 bg-gradient-to-br rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 flex-shrink-0 ${index % 2 === 0 ? 'from-primary-400 via-primary-500 to-primary-600 shadow-primary-500/30' : 'from-accent-400 via-accent-500 to-accent-600 shadow-accent-500/30'}`}>
                {advantage.icon === 'zap' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                )}
                {advantage.icon === 'user-check' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
                {advantage.icon === 'heart' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                )}
                {!['zap', 'user-check', 'heart'].includes(advantage.icon) && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                )}
              </div>
              <div class="flex-1">
                <h3 class={`text-xl font-bold text-gray-900 mb-3 transition-colors ${index % 2 === 0 ? 'group-hover:text-primary-600' : 'group-hover:text-accent-600'}`}>
                  {advantage.title}
                </h3>
                <p class="text-gray-600 leading-relaxed mb-4">
                  {advantage.description}
                </p>
                <div class={`flex items-center gap-2 font-medium text-sm ${index % 2 === 0 ? 'text-primary-600' : 'text-accent-600'}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Layanan Unggulan</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-12">
        <a
          href={identity?.contact?.whatsapp || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white px-8 py-4 rounded-2xl font-semibold hover:from-primary-600 hover:to-primary-700 transition-all duration-300 shadow-lg shadow-primary-500/30 hover:shadow-xl hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
